  "keyFeatures": [
    "Role-based access control (admin, delegado, tesorero, jugador)",
    "Player management with field-position visualization and avatar upload",
    "Match scheduling with convocation system and public confirmation links",
    "Tournament management with multi-series roster selection and Mapbox location picker",
    "Treasury module: fee rules, payment validation workflow, and Excel export",
    "Dynamic branding (primary color and logo configurable by admin)",
    "Dashboard with KPIs, upcoming matches, treasury summary, and birthday reminders",
    "Audit log for all admin actions",
    "PWA install prompt and dark mode support"
  ],
